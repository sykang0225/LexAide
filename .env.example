# ============================================================
# LexAide — 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 실제 키 입력
# cp .env.example .env
# ============================================================

# ── Groq API (런타임 판정 LLM) ──────────────────────────────
GROQ_API_KEY=gsk_여기에_실제_키_입력
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic API (이미지 OCR·성능 baseline 비교용) ─────────
ANTHROPIC_API_KEY=sk-ant-여기에_실제_키_입력
ANTHROPIC_MODEL=claude-opus-4-8
VISION_PROVIDER=anthropic          # anthropic / groq

# ── 국가법령정보 Open API ────────────────────────────────────
LAW_API_KEY=your_law_go_kr_OC_id   # law.go.kr 신청 시 발급되는 OC(이메일 ID)
LAW_API_URL=https://www.law.go.kr/DRF

# ── 앱 설정 ─────────────────────────────────────────────────
APP_ENV=development            # development / production
LOG_LEVEL=INFO
RECALL_THRESHOLD=0.35          # Recall 우선 임계값 (낮을수록 민감)
OCR_ENGINE=auto                # auto / easyocr / tesseract / paddle
EASY_OCR_LANGS=ko,en           # Korean + English/Latin text
EASY_OCR_GPU=0                 # 1 if local GPU OCR is configured
PADDLE_OCR_LANG=korean         # korean / en / latin 등 PaddleOCR 설치 시 사용

# ── DB ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./cross_check_ai.db
